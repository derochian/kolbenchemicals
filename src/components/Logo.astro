---
interface Props {
  height?: string;
}

const { height = '44px' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<img
  src={`${base}/images/kolben-logo.svg`}
  alt="Kolben Chemicals"
  class="logo-svg"
  style={`height: ${height}; width: auto;`}
  width="434"
  height="136"
/>

<style>
  .logo-svg {
    display: block;
  }
</style>
