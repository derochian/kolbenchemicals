---
interface Props {
  variant?: 'color' | 'white';
  height?: string;
}

const { variant = 'color', height = '44px' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<img
  src={`${base}/images/kolben-logo.svg`}
  alt="Kolben Chemicals"
  class:list={['logo-img', { 'logo-img--white': variant === 'white' }]}
  style={`height: ${height}; width: auto;`}
  loading="eager"
/>

<style>
  .logo-img {
    display: block;
    height: auto;
    object-fit: contain;
  }

  .logo-img--white {
    filter: brightness(0) invert(1);
  }
</style>
